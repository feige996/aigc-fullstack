{
  "name": "zhishu-platform",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "turbo run dev @aigc/ai-service#worker '--filter=./apps/*'",
    "dev:apps": "turbo dev '--filter=./apps/*'",
    "dev:generation": "turbo run @aigc/web#dev @aigc/api#dev @aigc/ai-service#worker",
    "doctor": "node scripts/dev/doctor.mjs",
    "setup": "node scripts/dev/setup.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "smoke:generation": "node scripts/dev/smoke-generation.mjs",
    "verify:docker-builds": "node scripts/dev/verify-docker-builds.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,vue,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.0"
  }
}
