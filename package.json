{
  "name": "aigc-fullstack",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "turbo dev --filter=./apps/*",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "smoke:generation": "node scripts/dev/smoke-generation.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,vue,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.0"
  }
}
