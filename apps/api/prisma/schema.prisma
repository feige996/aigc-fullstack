generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Task {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  projectId        String?       @map("project_id")
  type             String
  model            String
  status           TaskStatus
  stage            String
  failureCode      FailureCode?  @map("failure_code")
  billingStatus    BillingStatus @default(none) @map("billing_status")
  currentAttemptId String?       @unique @map("current_attempt_id")
  maxAttempts      Int           @default(3) @map("max_attempts")
  inputPayload     Json          @map("input_payload")
  resultPayload    Json?         @map("result_payload")
  usagePayload     Json?         @map("usage_payload")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  completedAt      DateTime?     @map("completed_at")

  attempts       TaskAttempt[] @relation("TaskAttempts")
  currentAttempt TaskAttempt?  @relation("CurrentAttempt", fields: [currentAttemptId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  project        Project?      @relation(fields: [projectId], references: [id])
  assets         Asset[]

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
  @@index([model, createdAt])
  @@index([failureCode, createdAt])
  @@map("tasks")
}

model User {
  id           String     @id @default(cuid())
  phoneNumber  String     @map("phone_number")
  passwordHash String     @map("password_hash")
  displayName  String?    @map("display_name")
  role         UserRole   @default(user)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tasks         Task[]
  refreshTokens RefreshToken[]
  projects      Project[]
  assets        Asset[]

  @@unique([phoneNumber])
  @@index([role, createdAt])
  @@index([status, createdAt])
  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  name        String
  description String?
  status      ProjectStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  tasks  Task[]
  assets Asset[]

  @@unique([userId, name])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("projects")
}

model Asset {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  projectId String?     @map("project_id")
  taskId    String?     @map("task_id")
  type      AssetType
  status    AssetStatus @default(temporary)
  provider  String
  bucket    String
  objectKey String      @map("object_key")
  mimeType  String      @map("mime_type")
  size      Int?
  checksum  String?
  width     Int?
  height    Int?
  duration  Int?
  expiresAt DateTime?   @map("expires_at")
  deletedAt DateTime?   @map("deleted_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])

  @@unique([bucket, objectKey])
  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
  @@index([status, createdAt])
  @@map("assets")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

model TaskAttempt {
  id               String        @id @default(cuid())
  taskId           String        @map("task_id")
  attemptNo        Int           @map("attempt_no")
  status           AttemptStatus
  stage            String
  provider         String?
  providerTaskId   String?       @map("provider_task_id")
  failureCode      FailureCode?  @map("failure_code")
  retryable        Boolean       @default(true)
  idempotencyKey   String        @unique @map("idempotency_key")
  inputPayloadHash String        @map("input_payload_hash")
  rawError         Json?         @map("raw_error")
  startedAt        DateTime?     @map("started_at")
  endedAt          DateTime?     @map("ended_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  task           Task  @relation("TaskAttempts", fields: [taskId], references: [id])
  currentForTask Task? @relation("CurrentAttempt")

  @@unique([taskId, attemptNo])
  @@index([taskId, status])
  @@index([provider, providerTaskId])
  @@index([failureCode, createdAt])
  @@map("task_attempts")
}

enum TaskStatus {
  draft
  validating
  rejected
  pending
  queued
  running
  retrying
  succeeded
  failed
  final_failed
  canceled
  expired
}

enum AttemptStatus {
  pending
  queued
  running
  succeeded
  failed
  canceled
}

enum UserRole {
  user
  admin
  super_admin
}

enum UserStatus {
  active
  disabled
}

enum ProjectStatus {
  active
  archived
}

enum AssetType {
  user_upload
  model_input
  model_output_raw
  processed_output
  preview
  cover
  watermarked
  source
  audit_sample
  temp
}

enum AssetStatus {
  temporary
  processing
  active
  blocked
  deleted
  expired
  orphaned
}

enum BillingStatus {
  none
  freezing
  frozen
  freeze_failed
  confirming
  confirmed
  releasing
  released
  refunding
  refunded
  adjust_required
}

enum FailureCode {
  INPUT_INVALID
  PROMPT_SENSITIVE
  TEXT_MODERATION_REJECTED
  ASSET_MODERATION_REJECTED
  RESULT_MODERATION_REJECTED
  QUOTA_NOT_ENOUGH
  BILLING_FREEZE_FAILED
  QUEUE_PUBLISH_FAILED
  WORKER_TIMEOUT
  PROVIDER_TIMEOUT
  PROVIDER_RATE_LIMITED
  PROVIDER_REJECTED
  PROVIDER_FAILED
  MEDIA_PROCESS_FAILED
  ASSET_UPLOAD_FAILED
  CALLBACK_FAILED
  BILLING_CONFIRM_FAILED
  USER_CANCELED
  SYSTEM_CANCELED
  UNKNOWN_ERROR
}
