{
  "extends": "../../packages/shared-config/tsconfig/base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "isolatedModules": false
  },
  "include": ["src/**/*.ts"]
}
